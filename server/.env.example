# ====== GuiZang 服务端配置（一体化部署） ======
# 复制为 .env 并按客户环境修改。采集引擎与本系统一起由 deploy.sh 一键部署。

# ---- GuiZang 仪表盘对外端口 ----
WEB_PORT=8080

# ---- PostgreSQL（存放 GuizangAI/AI 分析结论与趋势历史） ----
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=please-change-me
POSTGRES_DB=sentinel
# 数据库端口默认只绑定 127.0.0.1，后台管理员可在服务器本机或 SSH 隧道连接。
# 不建议直接对公网暴露数据库。
DB_PORT=5432

# ---- Wazuh 账号（BFF 与 Wazuh 服务共用，保持一致） ----
# 注意：indexer/dashboard 密码与 config/wazuh_indexer/internal_users.yml 中的哈希对应，
#       MVP 阶段请保持默认；如需改密码见 docs/DEPLOY.md「修改默认密码」。
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=MyS3cr37P450r.*-
INDEXER_USER=admin
INDEXER_PASSWORD=SecretPassword
ALERTS_INDEX=wazuh-alerts-*

# 自签证书环境保持 false（BFF 访问 Wazuh 用内部服务名）
VERIFY_TLS=false

# ---- Agent 注册密码（authd）----
# 留空时 deploy.sh 会自动生成随机注册密码，防止陌生设备注册。
# 注册密码不会写入公开下载页或 Agent 脚本，装机时按提示手动输入。
AGENT_REG_PASSWORD=

# ---- GuizangAI 对接点 ----
# 留空 = Mock 模式（无 GuizangAI 也能跑通全链路）。
# 在另一台有 GuizangAI 的机器上测试时，大多数情况【只改这里、无需改代码】：
#   1) 填 GUIZANGAI_BASE_URL 为 GuizangAI 机器地址，例如 http://192.168.1.50:1234
#   2) 选 GUIZANGAI_API_STYLE：openai（LM Studio/vLLM/llama.cpp/Ollama兼容，默认）| ollama | custom_sse
#   3) 填 GUIZANGAI_MODEL 为你的模型名/标签
GUIZANGAI_BASE_URL=
GUIZANGAI_API_STYLE=openai
GUIZANGAI_MODEL=guizangai-soc100-1.5b:q4
GUIZANGAI_API_KEY=
GUIZANGAI_CHAT_PATH=
GUIZANGAI_TIMEOUT_SECONDS=60
GUIZANGAI_MAX_NEW_TOKENS=96
GUIZANGAI_TEMPERATURE=0.4
# Ollama 推理参数：CPU/小显存可用 NUM_CTX=2048、NUM_GPU=0；GPU 机器可用 NUM_CTX=4096、NUM_GPU=999。
GUIZANGAI_NUM_CTX=4096
GUIZANGAI_KEEP_ALIVE=30m
GUIZANGAI_NUM_GPU=999
# 定时分析默认串行最稳；确认 Ollama 并发能力后可调到 2-3。
GUIZANGAI_ANALYSIS_CONCURRENCY=1
# 摘要不变时复用 AI 结果，避免重复推理。0 表示不按时间过期，只按摘要变化失效。
GUIZANGAI_ANALYSIS_CACHE_TTL_SECONDS=600
GUIZANGAI_ADVICE_CACHE_TTL_SECONDS=3600
GUIZANGAI_SEND_RAW_LOGS=false
GUIZANGAI_RAW_LOGS_MAX=20
GUIZANGAI_RAW_LOGS_FIELDS=timestamp,agent.name,rule.level,rule.description,rule.groups,rule.mitre.id,syscheck.path,syscheck.event,data.srcip,location

# ---- 分析调度 ----
# 生产建议 1-5 分钟；摘要缓存会跳过未变化数据的 AI 推理。
ANALYSIS_INTERVAL_MINUTES=1
SUMMARY_WINDOW=now-24h

# ---- 仪表盘登录 ----
# 登录令牌的签名密钥。留空时 deploy.sh 会自动生成一个随机长串写回这里。
# 切勿用默认/可猜的值：泄露后他人可伪造登录令牌绕过登录。改动后所有人需重新登录。
AUTH_SECRET=
# 默认管理员账号/密码（首次启动自动创建，登录后请在仪表盘内修改）。
DEFAULT_ADMIN_USER=testadmin
DEFAULT_ADMIN_PASSWORD=testpass

# ---- 其它 ----
# 生产建议改成实际访问域名，例如 http://example.com,https://example.com
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
TIMEZONE=Asia/Shanghai
