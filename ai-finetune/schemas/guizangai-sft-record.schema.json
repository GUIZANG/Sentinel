{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GuizangAI SFT Record",
  "type": "object",
  "required": ["task", "instruction", "input", "expected_output", "source", "review_status"],
  "additionalProperties": false,
  "properties": {
    "task": {
      "type": "string",
      "enum": ["overview", "alert_triage", "compliance", "alert_advice", "vuln_advice", "alert_description"]
    },
    "instruction": {
      "type": "string",
      "minLength": 8
    },
    "input": {
      "type": "object"
    },
    "expected_output": {
      "type": "object"
    },
    "source": {
      "type": "string",
      "description": "local_wazuh, cisa_kev, mitre_attack, sigma, public_wazuh, example, etc."
    },
    "review_status": {
      "type": "string",
      "enum": ["needs_review", "reviewed", "rejected"]
    },
    "license": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  }
}
